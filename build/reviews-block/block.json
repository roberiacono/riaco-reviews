{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "riaco-reviews/reviews-block",
  "version": "1.2.0",
  "title": "RIACO Reviews",
  "category": "widgets",
  "icon": "star-filled",
  "description": "Display a grid or masonry layout of customer reviews.",
  "example": {},
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "count": {
      "type": "integer",
      "default": 6
    },
    "layout": {
      "type": "string",
      "default": "grid"
    },
    "cardStyle": {
      "type": "string",
      "default": "default"
    },
    "headingLevel": {
      "type": "integer",
      "default": 3
    },
    "showAuthorName": {
      "type": "boolean",
      "default": true
    },
    "showAvatar": {
      "type": "boolean",
      "default": true
    },
    "showDate": {
      "type": "boolean",
      "default": true
    },
    "showRating": {
      "type": "boolean",
      "default": true
    },
    "showSource": {
      "type": "boolean",
      "default": true
    },
    "showProduct": {
      "type": "boolean",
      "default": true
    },
    "showTitle": {
      "type": "boolean",
      "default": true
    },
    "showShadow": {
      "type": "boolean",
      "default": true
    },
    "minWidth": {
      "type": "integer",
      "default": 300
    },
    "orderby": {
      "type": "string",
      "default": "date"
    },
    "order": {
      "type": "string",
      "default": "DESC"
    },
    "cardBg": {
      "type": "string",
      "default": ""
    },
    "cardTextColor": {
      "type": "string",
      "default": ""
    },
    "cardBorderColor": {
      "type": "string",
      "default": ""
    },
    "starColor": {
      "type": "string",
      "default": ""
    },
    "fontSize": {
      "type": "string",
      "default": ""
    },
    "lineHeight": {
      "type": "string",
      "default": ""
    },
    "productBg": {
      "type": "string",
      "default": ""
    },
    "productTextColor": {
      "type": "string",
      "default": ""
    },
    "productFilter": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "riaco-reviews",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css"
}