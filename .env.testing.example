# Copy this to .env.testing and fill in your local values.
# .env.testing is git-ignored — never commit real credentials.

DB_NAME=wp_test
DB_USER=root
DB_PASS=
DB_HOST=127.0.0.1
WP_VERSION=latest

# Path where bin/install-wp-tests.sh installs the WP test library.
WP_TESTS_DIR=/tmp/wordpress-tests-lib

# Path where WordPress core is installed for tests.
WP_CORE_DIR=/tmp/wordpress
